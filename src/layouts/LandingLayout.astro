---
const { title, description, ogImage } = Astro.props;
const SITE = 'https://clarencegono.com';
const og = ogImage ? (ogImage.startsWith('http') ? ogImage : SITE + ogImage) : undefined;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  {description && <meta name="description" content={description} />}
  <meta property="og:title" content={title} />
  {description && <meta property="og:description" content={description} />}
  <meta property="og:type" content="website" />
  {og && <meta property="og:image" content={og} />}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,900&family=Hanken+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet">
  <style is:global>
    .lp{--bone:#F7EDEC;--bone-2:#F0E2E2;--ink:#231019;--ink-soft:#4a313a;--rust:#BC3F69;--rust-deep:#8f2c4e;--line:#DBC5C9}
    .lp *{margin:0;padding:0;box-sizing:border-box}
    .lp{background:var(--bone);color:var(--ink);font-family:'Hanken Grotesk',sans-serif;font-size:19px;line-height:1.65;-webkit-font-smoothing:antialiased}
    .lp a{color:inherit}
    .lp .wrap{max-width:1080px;margin:0 auto;padding:0 28px}
    .lp .nav{position:sticky;top:0;z-index:50;background:rgba(247,237,236,.86);backdrop-filter:blur(8px);border-bottom:1px solid var(--line)}
    .lp .nav-inner{max-width:1180px;margin:0 auto;padding:0 28px;display:flex;align-items:center;justify-content:space-between;height:66px}
    .lp .brand{font-family:'Fraunces',serif;font-weight:600;font-size:21px;text-decoration:none}
    .lp .brand span{color:var(--rust)}
    .lp .nav-links{display:flex;gap:26px;align-items:center}
    .lp .nav-links a{font-size:15px;font-weight:500;text-decoration:none}
    .lp .nav-links a:hover{color:var(--rust)}
    .lp .nav-cta{border:1px solid var(--ink);padding:9px 16px;font-family:'JetBrains Mono',monospace;font-size:13px;letter-spacing:.04em}
    .lp .eyebrow{font-family:'JetBrains Mono',monospace;font-size:13px;font-weight:500;letter-spacing:.18em;text-transform:uppercase;color:var(--rust-deep)}
    .lp h1{font-family:'Fraunces',serif;font-weight:900;font-size:clamp(40px,6.5vw,76px);line-height:1.02;letter-spacing:-.03em;margin:18px 0 22px}
    .lp h1 em{font-style:italic;color:var(--rust)}
    .lp h2{font-family:'Fraunces',serif;font-weight:600;font-size:clamp(28px,3.6vw,40px);letter-spacing:-.02em;line-height:1.08;margin:0 0 18px}
    .lp h3{font-family:'Fraunces',serif;font-weight:600;font-size:23px;margin:0 0 8px}
    .lp .lead{font-size:21px;color:var(--ink-soft);max-width:60ch}
    .lp section{padding:74px 0;border-bottom:1px solid var(--line)}
    .lp .hero{padding:90px 0 70px;border-bottom:1px solid var(--line)}
    .lp .btns{display:flex;gap:14px;flex-wrap:wrap;margin-top:34px}
    .lp .btn{display:inline-block;text-decoration:none;font-weight:600;font-size:16px;padding:15px 26px}
    .lp .btn-primary{background:var(--rust);color:#fff}
    .lp .btn-primary:hover{background:var(--rust-deep)}
    .lp .btn-ghost{border:1px solid var(--ink)}
    .lp .btn-ghost:hover{background:var(--ink);color:var(--bone)}
    .lp .metrics{display:grid;grid-template-columns:repeat(4,1fr);gap:0;margin-top:54px;border-top:1px solid var(--line)}
    .lp .metric{padding:24px 22px 24px 0;border-right:1px solid var(--line)}
    .lp .metric:last-child{border-right:0}
    .lp .metric .n{font-family:'Fraunces',serif;font-weight:600;font-size:30px;line-height:1.05}
    .lp .metric .l{font-family:'JetBrains Mono',monospace;font-size:12px;letter-spacing:.1em;text-transform:uppercase;color:var(--rust-deep);margin-top:8px}
    .lp .dark{background:var(--ink);color:var(--bone)}
    .lp .dark .eyebrow{color:var(--rust)}
    .lp .cols{display:grid;grid-template-columns:repeat(2,1fr);gap:30px;margin-top:36px}
    .lp .card{background:var(--bone-2);padding:30px}
    .lp .card p{color:var(--ink-soft);margin-top:6px}
    .lp details{border-top:1px solid var(--line);padding:20px 0}
    .lp details summary{font-family:'Fraunces',serif;font-weight:600;font-size:21px;cursor:pointer;list-style:none;display:flex;justify-content:space-between;gap:20px}
    .lp details summary::-webkit-details-marker{display:none}
    .lp details summary::after{content:'+';color:var(--rust);font-family:'JetBrains Mono',monospace}
    .lp details[open] summary::after{content:'\2212'}
    .lp details p{color:var(--ink-soft);margin-top:14px;max-width:70ch}
    .lp .faq-wrap{border-bottom:1px solid var(--line);margin-top:24px}
    .lp .cta{text-align:center}
    .lp .cta h2{margin-left:auto;margin-right:auto;max-width:18ch}
    .lp footer{padding:40px 0}
    .lp .foot{font-family:'JetBrains Mono',monospace;font-size:13px;color:var(--ink-soft)}
    .lp .muted{color:var(--ink-soft)}
    .lp p + p{margin-top:16px}
    @media(max-width:760px){
      .lp .metrics{grid-template-columns:repeat(2,1fr)}
      .lp .metric{border-bottom:1px solid var(--line)}
      .lp .cols{grid-template-columns:1fr}
      .lp .nav-links a:not(.nav-cta){display:none}
    }
  </style>
</head>
<body>
  <div class="lp">
    <header class="nav">
      <div class="nav-inner">
        <a href="/" class="brand">Clarence <span>Gono</span></a>
        <nav class="nav-links">
          <a href="/">Home</a>
          <a href="/blog">Blog</a>
          <a class="nav-cta" href="/#contact">Get in touch</a>
        </nav>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <footer>
      <div class="wrap foot">&copy; 2026 Clarence Gono &middot; Real estate web development and SEO &middot; (remote, US clients)</div>
    </footer>
  </div>
</body>
</html>
