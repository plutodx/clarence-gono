---
const { title, description, image } = Astro.props;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  {description && <meta name="description" content={description} />}
  <meta property="og:title" content={title} />
  {description && <meta property="og:description" content={description} />}
  <meta property="og:type" content="article" />
  {image && <meta property="og:image" content={image} />}
  {image && <meta name="twitter:card" content="summary_large_image" />}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600;9..144,900&family=Hanken+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500;700&display=swap" rel="stylesheet">
  <style is:global>
    /* Palette matches the homepage. These are the pink values. */
    :root{--bone:#F7EDEC;--bone-2:#F0E2E2;--ink:#231019;--ink-soft:#4a313a;--rust:#BC3F69;--rust-deep:#8f2c4e;--line:#DBC5C9;--maxw:820px}
    *{margin:0;padding:0;box-sizing:border-box}
    html{scroll-behavior:smooth}
    body{background:var(--bone);color:var(--ink);font-family:'Hanken Grotesk',sans-serif;font-size:19px;line-height:1.65;-webkit-font-smoothing:antialiased}
    .wrap{max-width:var(--maxw);margin:0 auto;padding:0 28px}
    a{color:inherit}
    header.nav{position:sticky;top:0;z-index:50;background:rgba(247,237,236,.86);backdrop-filter:blur(8px);border-bottom:1px solid var(--line)}
    .nav-inner{max-width:1180px;margin:0 auto;padding:0 28px;display:flex;align-items:center;justify-content:space-between;height:66px}
    .brand{font-family:'Fraunces',serif;font-weight:600;font-size:21px;text-decoration:none}
    .brand span{color:var(--rust)}
    .nav-links{display:flex;gap:28px;align-items:center}
    .nav-links a{font-size:15px;font-weight:500;text-decoration:none}
    .nav-links a:hover{color:var(--rust)}
    footer{border-top:1px solid var(--line);padding:40px 0;margin-top:80px}
    .foot{max-width:1180px;margin:0 auto;padding:0 28px;font-family:'JetBrains Mono',monospace;font-size:13px;color:var(--ink-soft)}
    .eyebrow{font-family:'JetBrains Mono',monospace;font-size:13px;font-weight:500;letter-spacing:.18em;text-transform:uppercase;color:var(--rust-deep)}
    article h2{font-family:'Fraunces',serif;font-weight:600;font-size:clamp(26px,3.4vw,34px);letter-spacing:-.02em;margin:42px 0 14px;line-height:1.1}
    article h3{font-family:'Fraunces',serif;font-weight:600;font-size:23px;margin:30px 0 10px}
    article p{margin:0 0 20px}
    article ul,article ol{margin:0 0 20px 22px}
    article li{margin-bottom:8px}
    article a{color:var(--rust);text-decoration:underline;text-underline-offset:3px}
    article img{max-width:100%;height:auto;border-radius:6px;border:1px solid var(--line);margin:24px 0}
    article blockquote{border-left:3px solid var(--rust);padding-left:20px;margin:24px 0;font-family:'Fraunces',serif;font-size:22px;font-style:italic;color:var(--ink-soft)}
    article code{font-family:'JetBrains Mono',monospace;font-size:.85em;background:var(--bone-2);padding:2px 6px;border-radius:3px}
    .post-meta{font-family:'JetBrains Mono',monospace;font-size:13px;color:var(--ink-soft);letter-spacing:.04em;margin-bottom:36px}
    .hero-img{width:100%;height:auto;border-radius:8px;border:1px solid var(--line);margin:10px 0 36px}
  </style>
</head>
<body>
  <header class="nav">
    <div class="nav-inner">
      <a href="/" class="brand">Clarence <span>Gono</span></a>
      <nav class="nav-links">
        <a href="/">Home</a>
        <a href="/blog">Blog</a>
        <a href="/#contact">Contact</a>
      </nav>
    </div>
  </header>
  <main>
    <slot />
  </main>
  <footer><div class="foot">&copy; 2026 Clarence Gono &middot; Real Estate Web &amp; SEO</div></footer>
</body>
</html>
