---
import { getCollection } from 'astro:content';
import BlogLayout from '../../layouts/BlogLayout.astro';

// Astro 4 note: use `post.slug` instead of `post.id` below.
const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const fmt = (d) => d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---
<BlogLayout title="Blog | Clarence Gono" description="Notes on real estate web development, SEO, and getting found by AI.">
  <section class="wrap" style="padding:72px 0 18px">
    <p class="eyebrow">Writing</p>
    <h1 style="font-family:'Fraunces',serif;font-weight:900;font-size:clamp(36px,6vw,64px);line-height:1;letter-spacing:-.03em;margin:14px 0 14px">Notes from the build.</h1>
    <p style="font-size:20px;color:var(--ink-soft);max-width:48ch">Real estate websites, SEO, and the AI-visibility stuff most people haven't figured out yet.</p>
  </section>
  <section class="wrap" style="padding:24px 0 40px">
    {posts.length === 0 && <p style="color:var(--ink-soft)">No posts yet. First one's coming.</p>}
    <ul style="list-style:none;border-top:1px solid var(--line)">
      {posts.map((post) => (
        <li style="border-bottom:1px solid var(--line)">
          <a href={`/blog/${post.id}/`} style="display:block;padding:30px 4px;text-decoration:none">
            <span class="eyebrow">{fmt(post.data.pubDate)}</span>
            <h2 style="font-family:'Fraunces',serif;font-weight:600;font-size:clamp(24px,3.2vw,32px);letter-spacing:-.015em;margin:10px 0 8px;line-height:1.08">{post.data.title}</h2>
            <p style="color:var(--ink-soft);font-size:17.5px;max-width:60ch">{post.data.description}</p>
          </a>
        </li>
      ))}
    </ul>
  </section>
</BlogLayout>
