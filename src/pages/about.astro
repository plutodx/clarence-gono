---
import { getCollection } from "astro:content";

const blogPosts = await getCollection("blog");
const recentPosts = blogPosts
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 3);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Clarence Gono. Real estate web developer & SEO specialist. Builds ranked websites for luxury agents on Sierra Interactive and Luxury Presence." />
    <meta name="og:title" content="Clarence Gono — Real Estate Web & SEO" />
    <meta name="og:description" content="Real estate web developer & SEO specialist building ranked websites for luxury agents." />
    <meta name="og:type" content="website" />
    <meta name="og:url" content="https://clarencegono.com/about/" />
    <title>About — Clarence Gono</title>
    
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@72,600&family=Hanken+Grotesk:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    
    <style>
      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }

      body {
        font-family: "Hanken Grotesk", sans-serif;
        color: #231019;
        background-color: #F7EDEC;
        line-height: 1.6;
      }

      header {
        padding: 2rem 1.5rem;
        display: flex;
        justify-content: space-between;
        align-items: center;
        background-color: #F7EDEC;
        border-bottom: 1px solid #DBC5C9;
      }

      .logo {
        font-family: "Fraunces", serif;
        font-size: 1.5rem;
        font-weight: 600;
        color: #231019;
        text-decoration: none;
      }

      nav a {
        color: #231019;
        text-decoration: none;
        margin-left: 2rem;
        font-size: 0.95rem;
        transition: color 0.2s;
      }

      nav a:hover {
        color: #BC3F69;
      }

      .hero {
        padding: 4rem 1.5rem;
        max-width: 1000px;
        margin: 0 auto;
      }

      .bio-container {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 3rem;
        align-items: center;
        margin-bottom: 5rem;
      }

      .bio-image {
        display: flex;
        justify-content: center;
      }

      .bio-image img {
        width: 200px;
        height: 200px;
        border-radius: 50%;
        object-fit: cover;
        object-position: center 75%;
        border: 3px solid #BC3F69;
        box-shadow: 0 8px 24px rgba(188, 63, 105, 0.15);
      }

      .bio-text h1 {
        font-family: "Fraunces", serif;
        font-size: 3rem;
        margin-bottom: 0.5rem;
        color: #231019;
        line-height: 1.1;
      }

      .bio-text p {
        font-size: 1.1rem;
        margin-bottom: 1.5rem;
        color: #231019;
        line-height: 1.7;
      }

      .bio-text .headline {
        color: #BC3F69;
        font-family: "JetBrains Mono", monospace;
        font-size: 0.9rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        margin-bottom: 1rem;
      }

      .credentials {
        margin: 2rem 0;
        padding: 1.5rem;
        background-color: rgba(188, 63, 105, 0.08);
        border-left: 4px solid #BC3F69;
      }

      .credentials p {
        margin-bottom: 0.5rem;
        font-size: 0.95rem;
      }

      .cta-button {
        display: inline-block;
        padding: 1rem 2rem;
        background-color: #BC3F69;
        color: #F7EDEC;
        text-decoration: none;
        border-radius: 4px;
        font-weight: 600;
        transition: background-color 0.2s;
        margin-top: 1rem;
      }

      .cta-button:hover {
        background-color: #8f2c4e;
      }

      .services {
        margin: 3rem 0;
        padding: 2rem;
        background-color: white;
        border-radius: 4px;
      }

      .services h2 {
        font-family: "Fraunces", serif;
        font-size: 1.8rem;
        margin-bottom: 1.5rem;
        color: #231019;
      }

      .services-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 1.5rem;
      }

      .service-item {
        padding: 1rem;
      }

      .service-item h3 {
        font-weight: 600;
        margin-bottom: 0.5rem;
        color: #BC3F69;
      }

      .service-item p {
        font-size: 0.95rem;
        line-height: 1.6;
      }

      .contact-section {
        margin: 3rem 0;
        padding: 2rem;
        background-color: #8f2c4e;
        color: #F7EDEC;
        border-radius: 4px;
        text-align: center;
      }

      .contact-section h2 {
        font-family: "Fraunces", serif;
        font-size: 2rem;
        margin-bottom: 1rem;
      }

      .contact-section p {
        font-size: 1.05rem;
        margin-bottom: 1.5rem;
      }

      .contact-link {
        color: #F7EDEC;
        text-decoration: underline;
      }

      footer {
        padding: 2rem 1.5rem;
        text-align: center;
        color: #231019;
        font-size: 0.9rem;
        border-top: 1px solid #DBC5C9;
      }

      @media (max-width: 768px) {
        .bio-container {
          grid-template-columns: 1fr;
          gap: 2rem;
        }

        .bio-text h1 {
          font-size: 2rem;
        }

        nav a {
          margin-left: 1rem;
        }
      }
    </style>
  </head>
  <body>
    <header>
      <a href="/" class="logo">clarence gono</a>
      <nav>
        <a href="/">Work</a>
        <a href="/blog/">Blog</a>
